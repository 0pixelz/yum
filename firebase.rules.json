{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "$roomId.matches(/^[A-Z0-9]{4,8}$/)",

        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now && newData.val() > now - 86400000"
        },
        "hostUid": {
          ".validate": "newData.isString() && (!data.exists() || data.val() === auth.uid || newData.val() === auth.uid)"
        },
        "currentTurnId": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "mode": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "started": {
          ".validate": "newData.isBoolean()"
        },
        "rollCount": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3"
        },
        "dice": {
          "$index": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 6"
          }
        },
        "held": {
          "$index": {
            ".validate": "newData.isBoolean()"
          }
        },

        "players": {
          "$playerId": {
            ".write": "auth != null && (auth.uid === $playerId || !data.exists() || data.child('uid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['name'])",

            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "uid": {
              ".validate": "newData.isString() && newData.val() === auth.uid"
            },
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
            },
            "scorecard": {
              "$category": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
              }
            },
            "ready": {
              ".validate": "newData.isBoolean()"
            },
            "skin": {
              ".validate": "newData.isString() && newData.val().length <= 30"
            },
            "joinedAt": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            }
          }
        },

        "reactions": {
          "$reactionId": {
            ".validate": "newData.hasChildren(['emoji', 'uid', 'ts']) && newData.child('uid').val() === auth.uid && newData.child('ts').val() <= now",
            "emoji": { ".validate": "newData.isString() && newData.val().length <= 8" },
            "uid":   { ".validate": "newData.isString() && newData.val() === auth.uid" },
            "ts":    { ".validate": "newData.isNumber()" }
          }
        }
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "credits": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
        },
        "skins": {
          "$skinId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "achievements": {
          "$achId": {
            ".validate": "newData.isBoolean() || newData.isNumber()"
          }
        },
        "stats": {
          ".validate": "newData.hasChildren()"
        },
        "lastDailyBonus": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        }
      }
    }
  }
}
