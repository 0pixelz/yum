{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".validate": "$roomId.matches(/^[A-Z0-9]{4,8}$/)",
        ".write": "auth != null && (!data.exists() || !newData.exists())",

        "createdAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() <= now && newData.val() > now - 86400000"
        },
        "host": {
          ".write": "auth != null && (!data.exists() || data.val() === auth.uid || !data.parent().child('players/' + data.val()).exists() || data.parent().child('players/' + data.val() + '/disconnectedAt').exists())",
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "hostUid": {
          ".write": "auth != null",
          ".validate": "newData.isString() && (!data.exists() || data.val() === auth.uid || newData.val() === auth.uid)"
        },
        "currentTurn": {
          ".write": "auth != null",
          ".validate": "(!newData.exists()) || (newData.isString() && newData.val().length <= 50)"
        },
        "currentTurnId": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "gameMode": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('host').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "mode": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "started": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('host').val() === auth.uid",
          ".validate": "newData.isBoolean()"
        },
        "status": {
          ".write": "auth != null",
          ".validate": "newData.isString() && newData.val().length <= 20"
        },
        "roundId": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('host').val() === auth.uid",
          ".validate": "newData.isNumber()"
        },
        "rollCount": {
          ".write": "auth != null",
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3"
        },
        "gameOver": {
          ".write": "auth != null"
        },
        "firstRoll": {
          ".write": "auth != null"
        },
        "rematch": {
          ".write": "auth != null"
        },
        "rematchVotes": {
          ".write": "auth != null"
        },
        "rematchCommand": {
          ".write": "auth != null"
        },
        "dice": {
          ".write": "auth != null",
          "$index": {
            ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 6"
          }
        },
        "held": {
          ".write": "auth != null",
          "$index": {
            ".validate": "newData.isBoolean()"
          }
        },

        "players": {
          ".write": "auth != null && root.child('rooms').child($roomId).child('host').val() === auth.uid",
          "$playerId": {
            ".write": "auth != null && (auth.uid === $playerId || (!data.exists() && newData.child('uid').val() === auth.uid) || data.child('uid').val() === auth.uid || root.child('rooms').child($roomId).child('host').val() === auth.uid)",
            ".validate": "(!newData.exists()) || newData.hasChildren(['name'])",

            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 20"
            },
            "uid": {
              ".validate": "newData.isString() && newData.val() === auth.uid"
            },
            "joined": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "joinedAt": {
              ".validate": "newData.isNumber() && newData.val() <= now"
            },
            "disconnectedAt": {
              ".validate": "(!newData.exists()) || newData.isNumber()"
            },
            "lastActiveAt": {
              ".validate": "newData.isNumber()"
            },
            "ready": {
              ".validate": "newData.isBoolean()"
            },
            "skin": {
              ".validate": "newData.isString() && newData.val().length <= 30"
            },
            "perDieColors": {
              ".validate": "(!newData.exists()) || newData.isString() || newData.hasChildren()"
            },
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000"
            },
            "scorecard": {
              "$category": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100"
              }
            },
            "scores": {
              "ones":       { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5"  },
              "twos":       { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10" },
              "threes":     { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 15" },
              "fours":      { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 20" },
              "fives":      { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 25" },
              "sixes":      { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
              "threeKind":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
              "fourKind":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
              "fullHouse":  { ".validate": "newData.isNumber() && (newData.val() === 0 || newData.val() === 25)" },
              "smStraight": { ".validate": "newData.isNumber() && (newData.val() === 0 || newData.val() === 15 || newData.val() === 30)" },
              "lgStraight": { ".validate": "newData.isNumber() && (newData.val() === 0 || newData.val() === 20 || newData.val() === 40)" },
              "yum":        { ".validate": "newData.isNumber() && (newData.val() === 0 || newData.val() === 30 || newData.val() === 50)" },
              "chance":     { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 30" },
              "$other":     { ".validate": false }
            },
            "liveDice": {
              "dice": {
                "$index": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 6" }
              },
              "held": {
                "$index": { ".validate": "newData.isBoolean()" }
              },
              "roll":         { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3" },
              "skin":         { ".validate": "newData.isString() && newData.val().length <= 30" },
              "perDieColors": { ".validate": "(!newData.exists()) || newData.isString() || newData.hasChildren()" },
              "ts":           { ".validate": "newData.isNumber()" }
            },
            "livePowerups": {
              ".validate": "(!newData.exists()) || newData.hasChildren()",
              "inventory": {
                ".validate": "(!newData.exists()) || (newData.hasChildren() && newData.numChildren() <= 8)",
                "$idx": {
                  ".validate": "newData.isString() && (newData.val() === 'extraRoll' || newData.val() === 'freezeDie' || newData.val() === 'doublePoints' || newData.val() === 'luckyDice' || newData.val() === 'undoMove')"
                }
              },
              "pending": {
                ".validate": "(!newData.exists()) || (newData.isString() && (newData.val() === 'extraRoll' || newData.val() === 'freezeDie' || newData.val() === 'doublePoints' || newData.val() === 'luckyDice' || newData.val() === 'undoMove'))"
              },
              "doubleActive": { ".validate": "newData.isBoolean()" },
              "ts":           { ".validate": "newData.isNumber()" },
              "$other":       { ".validate": false }
            }
          }
        },

        "reactions": {
          ".write": "auth != null",
          "$reactionId": {
            ".validate": "newData.hasChildren(['ts'])",
            "from":      { ".validate": "newData.isString() && newData.val().length <= 50" },
            "fromName":  { ".validate": "newData.isString() && newData.val().length <= 20" },
            "to":        { ".validate": "newData.isString() && newData.val().length <= 50" },
            "toName":    { ".validate": "newData.isString() && newData.val().length <= 20" },
            "emoji":     { ".validate": "newData.isString() && newData.val().length <= 200" },
            "label":     { ".validate": "newData.isString() && newData.val().length <= 40" },
            "uid":       { ".validate": "newData.isString() && newData.val() === auth.uid" },
            "ts":        { ".validate": "newData.isNumber() && newData.val() <= now + 5000" }
          }
        },

        "_listenAt": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isNumber() && newData.val() <= now + 5000"
          }
        },

        "rematch2": {
          "command": {
            ".write": "auth != null && root.child('rooms').child($roomId).child('host').val() === auth.uid",
            "id":        { ".validate": "newData.isString() && newData.val().length <= 80" },
            "createdBy": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "createdAt": { ".validate": "newData.isNumber() && newData.val() <= now + 5000" }
          },
          "votes": {
            ".write": "auth != null && root.child('rooms').child($roomId).child('host').val() === auth.uid",
            "$voterId": {
              ".write": "auth != null && auth.uid === $voterId",
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },

    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",

        "credits": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000000"
        },
        "skins": {
          "$skinId": {
            ".validate": "newData.isBoolean()"
          }
        },
        "achievements": {
          "$achId": {
            ".validate": "newData.isBoolean() || newData.isNumber()"
          }
        },
        "stats": {
          ".validate": "newData.hasChildren()"
        },
        "lastDailyBonus": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },
        "displayName": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        }
      }
    }
  }
}
